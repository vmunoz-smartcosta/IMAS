<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <package android:name="com.zebra.scannercontrol" />
        <package android:name="com.zebra.rfid.rfidmanager" />
        <package android:name="com.symbol.datawedge" />
        <package android:name="com.zebra.rfid.service" />
        <intent>
            <action android:name="com.zebra.rfid.api3.READER_EVENT" />
        </intent>
    </queries>

    <!-- To auto-complete the email text field in the login form with the user's emails -->
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />
    <uses-permission android:name="android.permission.READ_PROFILE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- uses-permission android:name="android.permission.CALL_PHONE" /-->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Permisos básicos de Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"/>

    <!-- Permisos para versiones de Android 12 y superiores -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE"/>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:configChanges="screenSize|orientation"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/AppTheme"
        android:windowSoftInputMode="stateHidden"
        android:requestLegacyExternalStorage="true">
        <activity android:name=".CarruselCompleto.CarruselFotosActivo"></activity>
        <activity
            android:name=".login.LoginActivity"
            android:label="@string/title_activity_main"
            android:windowSoftInputMode="stateHidden"
            android:screenOrientation="portrait"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Main.MainActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:screenOrientation="portrait"/>
        <activity android:name=".Assign_tag_Assets.Asignar_tag_activo" />
        <activity android:name=".Assign_tag_Assets.GrabarTagActivo" />
        <activity
            android:name=".Assign_tag_Offices.Asignar_tag_sector"
            android:label="@string/Sector"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Assign_tag_Offices.Grabar_Tag_Sector"
            android:label="@string/Sector"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity android:name=".Activo.activoPorDescripcion" />
        <activity android:name=".Activo.VerActivosActivity"
            android:label="Ver Activos Sincronizados"
            android:theme="@style/AppTheme.NoActionBar"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity android:name=".Locate_Assets.Localizar_activo" />
        <activity
            android:name=".Activo.createAssets"
            android:label="@string/crear"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Locate_Assets.AsignarUbicacion"
            android:label="@string/Ubicaciones"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>

        <activity android:name=".CreateAsset.SelectLocationActivity"
            android:parentActivityName=".Main.MainActivity"
            android:label="@string/UbicacionNuevoActivo"
            android:exported="true" />

        <activity android:name=".CreateAsset.RegisterAssetPrimaryActivity"
            android:parentActivityName=".CreateAsset.SelectLocationActivity"
            android:label="@string/DatosNuevoActivoObligatorios"
            android:exported="true" />

        <activity android:name=".CreateAsset.RegisterAssetSecondaryActivity"
            android:parentActivityName=".CreateAsset.RegisterAssetPrimaryActivity"
            android:label="@string/DatosNuevoActivoSecundarios"
            android:exported="true" />
        <activity
            android:name=".Tags.ClasificacionTags"
            android:label="@string/Tags"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Locate_Assets.AsignarUbicacionTodo"
            android:label="@string/Ubicaciones"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Locate_Assets.Actualizar_activo"
            android:label="@string/Actualizar"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity android:name=".Locate_Assets.Localizacion_activo" />
        <activity
            android:name=".Inventory.Cargar_Toma_Fisica"
            android:label="@string/SectorInventarios"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Inventory.ElegirUbicacion_TomaFisica"
            android:label="@string/SectorInventarios"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Inventory.Lectura_Inventario"
            android:label="@string/SectorInventarios"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Sincronizar.sincronizar_base"
            android:label="@string/Sincronizar"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".GeneralTag.ConfiguracionAntena"
            android:label="@string/Configuraciones"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Oficina.ActivosPorSector"
            android:label="@string/ActivosXSector"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".Oficina.MostrarActivosSector"
            android:label="@string/ActivosXSector"
            android:parentActivityName=".Main.MainActivity"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".SubActivos.SubActivoActivity"
            android:label="@string/SubActivos"
            android:parentActivityName=".Locate_Assets.Actualizar_activo"
            android:screenOrientation="portrait"/>
        <activity
            android:name=".FotoActivo.FotosActivosActivity"
            android:label="@string/FotosActivo"
            android:parentActivityName=".Locate_Assets.Actualizar_activo"
            android:screenOrientation="portrait"/>
    </application>
</manifest>