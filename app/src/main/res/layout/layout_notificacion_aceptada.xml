<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp">

        <android.support.v7.widget.Toolbar
            android:id="@+id/toolbars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/AcceptColor"
            android:minHeight="?attr/actionBarSize"
            android:theme="?attr/actionBarTheme"
            app:logo="@android:drawable/ic_dialog_alert"
            app:titleMarginStart="30dp"
            />

        <TextView
            android:id="@+id/txvTitleMessageDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignLeft="@+id/toolbar"
            android:layout_alignTop="@+id/toolbar"
            android:layout_alignRight="@+id/toolbar"
            android:layout_alignBottom="@+id/toolbar"
            android:layout_marginLeft="60sp"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:text="TITLE"
            android:textColor="@color/notificationTitle"
            android:textSize="19sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="20dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txvMessageDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message"
            android:textColor="@color/AcceptColor"
            android:textSize="18dp" />
    </LinearLayout>
</LinearLayout>