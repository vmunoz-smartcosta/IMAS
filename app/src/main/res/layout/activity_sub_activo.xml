                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:gravity="center"
                    android:text="No hay sub activos disponibles para visualizar"
                    />

            </LinearLayout>

        </LinearLayout>

