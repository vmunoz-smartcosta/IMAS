                    android:id="@+id/lbl_placa_crea"
                    android:layout_width="92dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placa_crea" />

                <EditText
                    android:id="@+id/txt_placa_crea"
