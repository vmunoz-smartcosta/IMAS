<?xml version="1.0" encoding="utf-8"?>
<android.widget.LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <android.support.v7.widget.CardView
        android:id="@+id/crvSubActivo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:layout_gravity="center"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="3dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginLeft="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/lbl_numeroActSub"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Número: " />
                <TextView
                    android:id="@+id/txtNumSubActivo"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:background="#00FFFFFF"
                    android:gravity="center"
                    android:text=""
                    android:textIsSelectable="false" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/lbl_PlacaS"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/placa" />
                <TextView
                    android:id="@+id/txt_PlacaSubActivo"
                    android:layout_width="fill_parent"
                    android:background="#00FFFFFF"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:gravity="center"
                    android:text=""
                    android:textIsSelectable="false" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/lbl_DescActS"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Descripción: " />
                <TextView
                    android:id="@+id/txtDescripcionSubActivo"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="#00FFFFFF"
                    android:layout_alignParentTop="true"
                    android:gravity="center"
                    android:textIsSelectable="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/lbl_EpcSub"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="EPC: " />
                <TextView
                    android:id="@+id/txtEPCSubActivo"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="#00FFFFFF"
                    android:layout_alignParentTop="true"
                    android:gravity="center"
                    android:textIsSelectable="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/lbl_lblEncargadoSub"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/encargado" />
                <TextView
                    android:id="@+id/txtEncargadoSubActivo"
                    android:layout_width="fill_parent"
                    android:background="#00FFFFFF"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:gravity="center"
                    android:text=""
                    android:textIsSelectable="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtSubAssetsAvailables"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:background="#00FFFFFF"
                    android:gravity="center"
                    android:text="No hay sub activos disponibles."
                    android:textIsSelectable="false" />
            </LinearLayout>
        </LinearLayout>
    </android.support.v7.widget.CardView>
</android.widget.LinearLayout>