<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    card_view:cardCornerRadius="4dp"
    card_view:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción del Activo"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">
            
            <TextView
                android:id="@+id/txtBarcode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Placa: 123456" />

            <TextView
                android:id="@+id/txtSerie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Serie: SN123456" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtMarcaModelo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marca - Modelo" />

        <TextView
            android:id="@+id/txtUbicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ubicación: Edificio - Piso - Oficina"
            android:textColor="#555555" />

        <TextView
            android:id="@+id/txtEncargado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Encargado: Nombre" />

        <TextView
            android:id="@+id/txtTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EPC: E200..."
            android:textSize="12sp" />
            
        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado: Bueno" />

    </LinearLayout>

</android.support.v7.widget.CardView>
