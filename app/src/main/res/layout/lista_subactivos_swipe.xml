<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/deleteBackgroundView"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#F23B3B">

        <ImageView
            android:id="@+id/imgDeleteSubAsset"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="10dp"
            android:contentDescription="@string/SubActivos"
            android:src="@drawable/ic_delete_black_24dp">
        </ImageView>
        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="10dp"
            android:layout_toStartOf="@+id/imgDeleteSubAsset"
            android:text="ELIMINAR"
            android:textColor="#fff"
            android:textSize="13dp"
            android:textStyle="bold"></TextView>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/rlInfo"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#fff"
        android:clickable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:layout_marginLeft="20dp"
            android:padding="3dp">

            <TextView
                android:id="@+id/txtSwipedNumero"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="16dp"
                android:paddingRight="16dp"
                android:text="NumeroActivo"/>
            <TextView
                android:id="@+id/txtSwipedPlaca"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingEnd="16dp"
                android:paddingRight="16dp"
                android:text="Placa"/>
            <TextView
                android:id="@+id/txtSwipedDescrip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingEnd="16dp"
                android:paddingRight="16dp"
                android:text="Descripcion"/>
            <TextView
                android:id="@+id/txtSwipedEncargado"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingEnd="16dp"
                android:paddingRight="16dp"
                android:text="Encargado"/>
        </LinearLayout>


    </RelativeLayout>

</FrameLayout>