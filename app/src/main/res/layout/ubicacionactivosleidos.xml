<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Locate_Assets.AsignarUbicacionTodo">

    <ScrollView
        android:id="@+id/elegirubicacion"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tituloasignacion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textAlignment="center"
            android:text="Reubicar activos"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp"
            />

        <LinearLayout
            android:id="@+id/space4"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:orientation="vertical"
            ></LinearLayout>

        <HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:id="@+id/buscarActivoDescripcion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            >


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="8dp"
                    >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/lbl_numeroAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:singleLine="true"
                                android:text="Número"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/lbl_placaAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="Placa"
                                android:textAllCaps="false"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/lbl_descripcionAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="Descripción"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/lbl_RazonAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="@string/RowCompanie"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/lbl_edificioAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="@string/Rowbuild"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_pisoAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="@string/Rowfloor"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_sectorAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="@string/RowOffice"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_encargadoAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="Encargado"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_marcaAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="Marca"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_modeloAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="Modelo"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_serieAct"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="Serie"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/lbl_tag"
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:gravity="center"
                                android:text="@string/RowTag"
                                android:textIsSelectable="false"
                                android:textSize="15dp"
                                android:textStyle="bold"
                                app:fontFamily="sans-serif" />
                        </LinearLayout>




                        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">



                            <ListView
                                android:id="@+id/listView"
                                android:layout_width="304dp"
                                android:layout_height="320dp"
                                android:layout_weight="1"
                                tools:layout_editor_absoluteX="8dp"
                                tools:layout_editor_absoluteY="8dp" />
                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

        </HorizontalScrollView>
        <TextView
            android:id="@+id/lblTipoUbicacion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textAlignment="center"
            android:text="Seleccione el tipo de ubicación"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp"
            />

        <LinearLayout
            android:id="@+id/Espacio4"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:orientation="vertical"
            ></LinearLayout>
    <LinearLayout
        android:id="@+id/PanelTituloRazon"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <TextView
            android:id="@+id/lbl_compania"
            android:layout_width="92dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/compañia_actualiza" />

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <!-- compania -->
    <LinearLayout
        android:id="@+id/Espacio5"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
        ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelRazonSpinner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <Spinner
            android:id="@+id/compania_toma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:ems="10"/>

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <!-- Edificio -->
    <LinearLayout
        android:id="@+id/Espacio6"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
        ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelTituloEdificio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <TextView
            android:id="@+id/lbl_edificio"
            android:layout_width="92dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/edificio_actualiza" />

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/Espacio7"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
       ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelEdificioSpinner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <Spinner
            android:id="@+id/edificio_toma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:ems="10"/>

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <!-- Piso -->
    <LinearLayout
        android:id="@+id/Espacio8"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
        ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelTituloPiso"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <TextView
            android:id="@+id/lbl_piso"
            android:layout_width="92dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/piso_actualiza" />

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/Espacio9"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
        ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelPisoSpinner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <Spinner
            android:id="@+id/piso_toma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:ems="10"/>

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <!-- Sector -->
    <LinearLayout
        android:id="@+id/Espacio10"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
        ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelTituloSector"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <TextView
            android:id="@+id/lbl_oficina"
            android:layout_width="89dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/oficina_actualiza" />

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/Espacio11"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:orientation="vertical"
        ></LinearLayout>

    <LinearLayout
        android:id="@+id/PanelSectorSpinner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="25dp"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:layout_width="17dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>

        <Spinner
            android:id="@+id/oficina_toma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:ems="10"/>

        <LinearLayout
            android:layout_width="14dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"></LinearLayout>
    </LinearLayout>
    </LinearLayout>
    </ScrollView>
</android.support.constraint.ConstraintLayout>